    echo "                        Redes Encontradas:"
    echo ""
    echo " ID      MAC                     CANAL   SEG.    SINAL    NOME"
    echo ""
    i=0

    while IFS=, read -r MAC FTS LTS CHANNEL SPEED PRIVACY CYPHER AUTH POWER BEACON IV LANIP IDLENGTH ESSID KEY; do
        longueur=${#MAC}
        PRIVACY=$(echo "$PRIVACY" | tr -d "^ ")
