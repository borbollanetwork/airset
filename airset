    idlenght=${aidlenght[$choice]}
    ssid=${assid[$choice]}
    channel=$(echo "${achannel[$choice]}" | tr -d '[:space:]')
    mac=${amac[$choice]}
    privacy=${aprivacy[$choice]}
    speed=${aspeed[$choice]}
    Host_IDL=$idlenght
    Host_SPEED=$speed
    Host_ENC=$privacy
    Host_MAC=$mac
    Host_CHAN=$channel
    acouper=${#ssid}
    fin=$(( acouper - idlenght ))
    Host_SSID=${ssid:1:fin}
    Host_SSID2=$(echo "$Host_SSID" | sed 's/ //g;s/\[//g;s/\]//g')
    conditional_clear
    askAP
}

