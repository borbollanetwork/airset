# KILL ALL — encerramento limpo
function exitmode() {
    conditional_clear
    top
    echo -e "\n\n${white}[${red}-${white}] ${red}${general_exitmode}${transparent}"

    for proc in aireplay-ng airodump-ng hostapd lighttpd dhcpd mdk3; do
        if pgrep -x "$proc" &>/dev/null; then
            echo -e "${white}[${red}-${white}] ${white}Encerrando ${grey}${proc}${transparent}"
            killall "$proc" &>"$flux_output_device"
        fi
    done

    # Encerra fakedns Python 3
    if pgrep -f "fakedns" &>/dev/null; then
        echo -e "${white}[${red}-${white}] ${white}Encerrando ${grey}fakedns${transparent}"
        pkill -f "fakedns" &>"$flux_output_device"
    fi

    if [ -n "$WIFI_MONITOR" ]; then
        echo -e "${white}[${red}-${white}] ${white}${general_exitmode_1} ${green}${WIFI_MONITOR}${transparent}"
        airmon-ng stop "$WIFI_MONITOR" &>"$flux_output_device"
    fi

    if [ -n "$WIFI" ]; then
        echo -e "${white}[${red}-${white}] ${white}${general_exitmode_2} ${green}${WIFI}${transparent}"
        for iface in $WIFI $WIFI_MONITOR1 $WIFI_MONITOR2 $WIFI_MONITOR3 $WIFI_MONITOR4 $WIFI_MONITOR5; do
            [ -n "$iface" ] && airmon-ng stop "$iface" &>"$flux_output_device"
        done
        macchanger -p "$WIFI" &>"$flux_output_device"
    fi

    if [ "$(cat /proc/sys/net/ipv4/ip_forward)" != "0" ]; then
        echo -e "${white}[${red}-${white}] ${white}${general_exitmode_3}${transparent}"
        sysctl -w net.ipv4.ip_forward=0 &>"$flux_output_device"
    fi

    echo -e "${white}[${red}-${white}] ${white}${general_exitmode_4}${transparent}"
    iptables --flush
    iptables --table nat --flush
    iptables --delete-chain
    iptables --table nat --delete-chain

    echo -e "${white}[${red}-${white}] ${white}${general_exitmode_5}${transparent}"
    tput cnorm

    if [ "$FLUX_DEBUG" != "1" ]; then
        echo -e "${white}[${red}-${white}] ${white}Removendo ${grey}arquivos temporários${transparent}"
        rm -rf "${DUMP_PATH:?}"/* &>"$flux_output_device"
    fi

    echo -e "${white}[${red}-${white}] ${white}${general_exitmode_6}${transparent}"
    # Parrot OS 7 usa systemctl
    systemctl restart NetworkManager &>"$flux_output_device" &

    echo -e "${white}[${green}+${white}] ${green}${general_exitmode_7}${transparent}"
    echo -e "${white}[${green}+${white}] ${grey}${general_exitmode_8}${transparent}"
    sleep 2
    clear
    exit 0
}

