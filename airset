}

function creassl() {
    xterm -title "Criar Certificado SSL" \
        -e openssl req -subj '/CN=SEGURO/O=SEGURA/OU=SEGURA/C=BR' \
           -new -newkey rsa:2048 -days 365 -nodes -x509 \
           -keyout /root/server.pem -out /root/server.pem
    certssl
}

