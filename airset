            if [ -n "$CLIENTE" ]; then
                CLIENTE="*"
                echo -e " ${red}[${white}${i}${red}]${green}${CLIENTE}\t${red}${MAC}\t${red}${CHANNEL}\t${green}${PRIVACY}\t  ${red}${POWER}%\t${red}${ESSID}${transparent}"
