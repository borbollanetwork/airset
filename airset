    fi

    if [ "$LINEAS_WIFIS_CSV" -le 3 ]; then
        deltax; return
    fi

    fluxionap=$(grep -an 'Station\|Cliente' "$DUMP_PATH/$CSVDB" | awk -F: '{print $1}' | head -1)
    fluxionap=$(( fluxionap - 1 ))
    head -n "$fluxionap" "$DUMP_PATH/$CSVDB" > "$DUMP_PATH/dump-02.csv"
