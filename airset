################################### < SELEÇÃO DE INTERFACE > ###################################
function setinterface() {
    conditional_clear
    top
    rfkill unblock all

    # Para todas as interfaces em modo monitor
    while IFS= read -r monkill; do
        [ -n "$monkill" ] && airmon-ng stop "$monkill" &>"$flux_output_device"
    done < <(iwconfig 2>&1 | grep Monitor | awk '{print $1}')

    # Lista interfaces wireless via airmon-ng (Parrot OS 7 compatível)
    readarray -t wirelessifaces < <(airmon-ng 2>/dev/null | grep -E '^[a-zA-Z]' | awk '{print $2}' | grep -v '^$')
    INTERFACESNUMBER=${#wirelessifaces[@]}

    if [ "$INTERFACESNUMBER" -gt "0" ]; then
        if [ "$INTERFACESNUMBER" -eq "1" ]; then
            PREWIFI="${wirelessifaces[0]}"
        else
            echo -e "$header_setinterface"
            echo
            for ((i=0; i<INTERFACESNUMBER; i++)); do
                echo -e "      ${red}[${yellow}$((i+1))${red}]${transparent} ${wirelessifaces[$i]}"
            done
            echo
            echo -n -e "${red}[${white}w4r10ck${white}@${white}airset${red}]-[${white}~${red}]${transparent}"
            read -r line
            idx=$((line-1))
            PREWIFI="${wirelessifaces[$idx]}"
        fi

        if [ ${#PREWIFI} -le 2 ]; then
            conditional_clear; top; setinterface; return
        fi

        # Para processos que interferem
        readarray -t naggysoftware < <(airmon-ng check "$PREWIFI" 2>/dev/null | tail -n +8 | grep -v "on interface" | awk '{print $2}')
        for nagger in "${naggysoftware[@]}"; do
            [ -n "$nagger" ] && killall "$nagger" &>"$flux_output_device"
        done
        sleep 0.5

        # Inicia modo monitor com airmon-ng
        WIFIMONITOR=$(airmon-ng start "$PREWIFI" 2>/dev/null | grep -oP '(?<=monitor mode vif enabled for \[phy\d+\])\S+|(?<=monitor mode enabled on )\S+' | head -1)
        # Fallback: tenta detectar pela saída padrão do airmon-ng
        if [ -z "$WIFIMONITOR" ]; then
            WIFIMONITOR=$(airmon-ng start "$PREWIFI" 2>/dev/null | grep -oP '\b\w+mon\b|\b\w+mon\d+\b' | head -1)
        fi
        # Último fallback: adiciona "mon" ao nome
        [ -z "$WIFIMONITOR" ] && WIFIMONITOR="${PREWIFI}mon"

        WIFI_MONITOR="$WIFIMONITOR"
        WIFI="$PREWIFI"
    else
        echo -e "$setinterface_error"
        sleep 5
        exitmode
    fi

    deltax
}

