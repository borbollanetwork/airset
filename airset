################################### < VERIFICAÇÃO DE DEPENDÊNCIAS > ###################################
function checkdependences() {

    local missing=0

    check_dep() {
        local name="$1"
        local cmd="${2:-$1}"
        local note="${3:-}"
        printf "%-20s" "$name"
        if command -v "$cmd" &>/dev/null || [ -x "$cmd" ]; then
            echo -e "${green}OK!${transparent}"
        else
            echo -e "${red}NÃO INSTALADO${transparent} ${note}"
            missing=1
        fi
        sleep 0.02
    }

    check_dep "aircrack-ng"
    check_dep "aireplay-ng"
    check_dep "airmon-ng"
    check_dep "airodump-ng"
    check_dep "awk"
    check_dep "bully"
    check_dep "curl"
    check_dep "dhcpd"          "dhcpd"        "(isc-dhcp-server)"
    check_dep "hostapd"
    check_dep "iwconfig"       "iwconfig"     "(wireless-tools)"
    check_dep "lighttpd"
    check_dep "macchanger"
    check_dep "mdk3"
    check_dep "nmap"
    check_dep "openssl"
    check_dep "pyrit"
    check_dep "python3"
    check_dep "reaver"
    check_dep "rfkill"
    check_dep "strings"        "strings"      "(binutils)"
    check_dep "fuser"          "fuser"        "(psmisc)"
    check_dep "unzip"
    check_dep "xterm"
    check_dep "zenity"

    # PHP-CGI — verificação separada pois pode ter nome versionado
    printf "%-20s" "php-cgi"
    if [ -n "$PHP_CGI" ]; then
        echo -e "${green}OK! ($PHP_CGI)${transparent}"
    else
        echo -e "${red}NÃO INSTALADO${transparent} (php8.2-cgi ou php-cgi)"
        missing=1
    fi
    sleep 0.02

    if [ "$missing" = "1" ]; then
        echo
        echo -e "${red}Instale as dependências faltantes e tente novamente.${transparent}"
        echo -e "${yellow}Dica (Parrot OS 7):${transparent} apt install aircrack-ng hostapd lighttpd isc-dhcp-server macchanger mdk3 reaver bully php8.2-cgi nmap pyrit rfkill binutils psmisc xterm zenity curl unzip"
        exit 1
    fi

    sleep 1
    clear
}

