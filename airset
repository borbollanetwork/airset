            echo -e "      ${red}[${yellow}3${red}]${red} Sair${transparent}"
            echo -n '      #> '
            read -r yn
            case $yn in
                1) creassl ;;
                2) certssl; break ;;
                3) exitmode; break ;;
                *) echo "$general_case_error"; conditional_clear ;;
            esac
        done
